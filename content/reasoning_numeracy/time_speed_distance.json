          "question": "A 150 m long train crosses a 250 m platform in 20 seconds. Its speed is:",
          "options": ["18 km/h", "36 km/h", "54 km/h", "72 km/h"],
          "answer": 3,
          "explanation": "Distance = 150+250=400 m, time = 20 s → speed = 400/20 = 20 m/s = 72 km/h.",
          "is_pyq": false
        },
        {
          "type": "mcq",
          "question": "A and B start from same point on a circular track of length 600 m. A speed = 10 m/s, B speed = 8 m/s, same direction. When will they meet again?",
