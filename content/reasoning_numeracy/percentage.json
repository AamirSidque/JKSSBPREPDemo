"title": "Ratio and Proportion",
"subtopics": [
{
  "id": "percentage_intro",
  "title": "Meaning of Percentage",
  "estimated_minutes": 5,
  "blocks": [
    {
      "type": "hero",
      "title": "Percentage",
      "subtitle": "Foundation of Numerical Ability",
      "tags": ["JKSSB", "High Weightage"]
    },
    {
      "type": "fact_card",
      "icon": "📊",
      "title": "Definition",
      "content": "Percentage means per hundred. It is a method of expressing any quantity as a fraction of 100.",
      "highlight": true
    },
    {
      "type": "fact_card",
      "icon": "📌",
      "title": "Symbol",
      "content": "Percentage is represented by the symbol (%). Example: 25% means 25 out of every 100."
    },
    {
      "type": "formula",
      "title": "Basic Formula",
      "formula": "Percentage = (Part / Whole) × 100",
      "description": "Used when part and total quantity are known."
    },
    {
      "type": "solved_example",
      "title": "Example 1",
      "given": [
        "Passed Students = 180",
        "Total Students = 240"
      ],
      "find": "Pass Percentage",
      "steps": [
        "Percentage = (180/240) × 100",
        "Percentage = 0.75 × 100",
        "Percentage = 75%"
      ],
      "answer": "75%",
      "formula_used": "Percentage = (Part/Whole) × 100"
    },
    {
      "type": "revision",
      "title": "Quick Revision",
      "points": [
        "Percentage means per hundred.",
        "Symbol used is %.",
        "Percentage is a fraction whose denominator is 100."
      ]
    }
  ]
},
{
  "id": "fraction_to_percentage",
  "title": "Fraction to Percentage Conversion",
  "estimated_minutes": 8,
  "blocks": [
    {
      "type": "hero",
      "title": "Fraction to Percentage",
      "subtitle": "Most Important Exam Conversions",
      "tags": ["Shortcut", "Frequently Asked"]
    },
    {
      "type": "formula",
      "title": "Conversion Formula",
      "formula": "Percentage = Fraction × 100",
      "description": "Multiply the fraction by 100."
    },
    {
      "type": "solved_example",
      "title": "Convert 3/4 into Percentage",
      "given": [
        "Fraction = 3/4"
      ],
      "find": "Percentage",
      "steps": [
        "Percentage = (3/4) × 100",
        "Percentage = 75%"
      ],
      "answer": "75%",
      "formula_used": "Fraction × 100"
    },
    {
      "type": "solved_example",
      "title": "Convert 1/5 into Percentage",
      "given": [
        "Fraction = 1/5"
      ],
      "find": "Percentage",
      "steps": [
        "Percentage = (1/5) × 100",
        "Percentage = 20%"
      ],
      "answer": "20%",
      "formula_used": "Fraction × 100"
    },
    {
      "type": "revision",
      "title": "Important Conversions",
      "points": [
        "1/2 = 50%",
        "1/3 = 33.33%",
        "1/4 = 25%",
        "3/4 = 75%",
        "1/5 = 20%",
        "1/8 = 12.5%",
        "1/10 = 10%"
      ]
    }
  ]
},
{
  "id": "percentage_to_fraction",
  "title": "Percentage to Fraction",
  "estimated_minutes": 8,
  "blocks": [
    {
      "type": "hero",
      "title": "Percentage to Fraction",
      "subtitle": "Reverse Conversion Technique",
      "tags": ["Shortcuts", "Important"]
    },
    {
      "type": "formula",
      "title": "Conversion Formula",
      "formula": "Fraction = Percentage / 100",
      "description": "Reduce to lowest terms."
    },
    {
      "type": "solved_example",
      "title": "Convert 40% into Fraction",
      "given": [
        "Percentage = 40%"
      ],
      "find": "Fraction",
      "steps": [
        "40/100",
        "Divide by 20",
        "2/5"
      ],
      "answer": "2/5",
      "formula_used": "Percentage/100"
    },
    {
      "type": "solved_example",
      "title": "Convert 75% into Fraction",
      "given": [
        "Percentage = 75%"
      ],
      "find": "Fraction",
      "steps": [
        "75/100",
        "Divide by 25",
        "3/4"
      ],
      "answer": "3/4",
      "formula_used": "Percentage/100"
    },
    {
      "type": "revision",
      "title": "Remember",
      "points": [
        "50% = 1/2",
        "25% = 1/4",
        "20% = 1/5",
        "75% = 3/4",
        "12.5% = 1/8"
      ]
    }
  ]
},
{
  "id": "percentage_increase",
  "title": "Percentage Increase",
  "estimated_minutes": 8,
  "blocks": [
    {
      "type": "hero",
      "title": "Percentage Increase",
      "subtitle": "Finding growth in a quantity",
      "tags": ["Important", "JKSSB"]
    },
    {
      "type": "fact_card",
      "icon": "📈",
      "title": "Concept",
      "content": "Percentage increase measures how much a quantity has increased relative to its original value.",
      "highlight": true
    },
    {
      "type": "formula",
      "title": "Percentage Increase Formula",
      "formula": "((New Value - Original Value) / Original Value) × 100",
      "description": "Always divide by the original value."
    },
    {
      "type": "solved_example",
      "title": "Example 1",
      "given": [
        "Original Price = 200",
        "New Price = 250"
      ],
      "find": "Percentage Increase",
      "steps": [
        "Increase = 250 - 200 = 50",
        "Percentage Increase = (50/200) × 100",
        "Percentage Increase = 25%"
      ],
      "answer": "25%",
      "formula_used": "Percentage Increase Formula"
    },
    {
      "type": "solved_example",
      "title": "Example 2",
      "given": [
        "Population = 5000",
        "Increased to 6500"
      ],
      "find": "Percentage Increase",
      "steps": [
        "Increase = 6500 - 5000 = 1500",
        "Percentage = (1500/5000) × 100",
        "Percentage = 30%"
      ],
      "answer": "30%",
      "formula_used": "Percentage Increase Formula"
    },
    {
      "type": "revision",
      "title": "Key Points",
      "points": [
        "Always use original value in denominator.",
        "Increase = New − Original.",
        "Result is expressed in percentage."
      ]
    }
  ]
},
{
  "id": "percentage_decrease",
  "title": "Percentage Decrease",
  "estimated_minutes": 8,
  "blocks": [
    {
      "type": "hero",
      "title": "Percentage Decrease",
      "subtitle": "Finding reduction in a quantity",
      "tags": ["Important"]
    },
    {
      "type": "formula",
      "title": "Percentage Decrease Formula",
      "formula": "((Original Value - New Value) / Original Value) × 100",
      "description": "Used when quantity decreases."
    },
    {
      "type": "solved_example",
      "title": "Example 1",
      "given": [
        "Original Salary = 40000",
        "Reduced Salary = 36000"
      ],
      "find": "Percentage Decrease",
      "steps": [
        "Decrease = 40000 - 36000 = 4000",
        "Percentage = (4000/40000) × 100",
        "Percentage = 10%"
      ],
      "answer": "10%",
      "formula_used": "Percentage Decrease Formula"
    },
    {
      "type": "exam_trap",
      "title": "Common Mistake",
      "wrong": "Using new value in denominator.",
      "correct": "Use original value in denominator.",
      "tip": "Most frequent aptitude mistake."
    },
    {
      "type": "revision",
      "title": "Quick Revision",
      "points": [
        "Decrease = Original − New.",
        "Divide by original value.",
        "Convert into percentage."
      ]
    }
  ]
},
{
  "id": "successive_percentage",
  "title": "Successive Percentage Change",
  "estimated_minutes": 10,
  "blocks": [
    {
      "type": "hero",
      "title": "Successive Percentage",
      "subtitle": "Two or More Percentage Changes",
      "tags": ["High Weightage"]
    },
    {
      "type": "fact_card",
      "icon": "⚡",
      "title": "Shortcut",
      "content": "When two percentage changes occur successively, use the net change formula.",
      "highlight": true
    },
    {
      "type": "formula",
      "title": "Successive Increase Formula",
      "formula": "a + b + (ab/100)",
      "description": "Used when both changes are increases."
    },
    {
      "type": "formula",
      "title": "Increase-Decrease Formula",
      "formula": "a - b - (ab/100)",
      "description": "Used when increase is followed by decrease."
    },
    {
      "type": "solved_example",
      "title": "Example 1",
      "given": [
        "Increase = 10%",
        "Increase Again = 20%"
      ],
      "find": "Net Percentage Increase",
      "steps": [
        "Net Change = 10 + 20 + (10×20)/100",
        "Net Change = 30 + 2",
        "Net Change = 32%"
      ],
      "answer": "32%",
      "formula_used": "a+b+ab/100"
    },
    {
      "type": "solved_example",
      "title": "Example 2",
      "given": [
        "Increase = 20%",
        "Decrease = 10%"
      ],
      "find": "Net Change",
      "steps": [
        "Net Change = 20 - 10 - (20×10)/100",
        "Net Change = 10 - 2",
        "Net Change = 8%"
      ],
      "answer": "8% Increase",
      "formula_used": "a-b-ab/100"
    },
    {
      "type": "exam_trap",
      "title": "Exam Trap",
      "wrong": "20% increase and 20% decrease cancel each other.",
      "correct": "They result in a net loss of 4%.",
      "tip": "Very common competitive exam question."
    },
    {
      "type": "revision",
      "title": "Remember",
      "points": [
        "Use a+b+ab/100 for two increases.",
        "Use a-b-ab/100 for opposite changes.",
        "Successive changes are not simple addition."
      ]
    }
  ]
},
